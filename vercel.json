{
  "installCommand": "cd projects/premiyerx/base_mvp && npm install",
  "buildCommand": "cd projects/premiyerx/base_mvp && npm run build",
  "outputDirectory": "projects/premiyerx/base_mvp/dist",
  "rewrites": [{ "source": "/(.*)", "destination": "/index.html" }],
  "functions": {
    "api/generate-image.js": {
      "maxDuration": 60
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
